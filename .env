# ORDER SERVICE
APP_PORT=8080
DB_DSN=host=localhost port=5433 user=postgres password=1234 dbname=order_db sslmode=disable

# PAYMENT SERVICE
PAYMENT_APP_PORT=8081
PAYMENT_DB_DSN=host=localhost port=5434 user=postgres password=1234 dbname=payment_db sslmode=disable

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Order -> Payment communication
PAYMENT_GRPC_ADDR=localhost:50051
HTTP_TIMEOUT_SECONDS=10

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# Cache TTL (seconds)
CACHE_TTL_SECONDS=300

# Rate Limiter (BONUS)
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# Notification Provider: SIMULATED or REAL
PROVIDER_MODE=SIMULATED

# SMTP settings (used when PROVIDER_MODE=REAL)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
